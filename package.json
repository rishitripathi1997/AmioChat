{
  "name": "amiochat",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @amiochat/web",
    "dev:ws": "npm run dev:ws --workspace @amiochat/backend",
    "build": "npm run build --workspaces --if-present",
    "build:backend": "npm run build --workspace @amiochat/backend",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
