{
  "name": "@amiochat/backend",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build:rest && npm run build:ws && npm run build:post-confirmation",
    "build:rest": "esbuild src/rest/handler.ts --bundle --platform=node --target=node20 --outfile=dist/rest/index.js --minify",
    "build:ws": "esbuild src/ws/handler.ts --bundle --platform=node --target=node20 --outfile=dist/ws/index.js --minify",
    "build:post-confirmation": "esbuild src/triggers/post-confirmation.ts --bundle --platform=node --target=node20 --outfile=dist/triggers/post-confirmation.js --minify",
    "dev:ws": "tsx src/ws/local-server.ts"
  },
  "dependencies": {
    "@amiochat/shared": "*",
    "@aws-sdk/client-chime-sdk-meetings": "^3.750.0",
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^20.17.14",
    "@types/ws": "^8.5.14",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
